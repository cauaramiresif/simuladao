<%- include('cabecalho.ejs')%>
<main class="container">
        <a href="/musica" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Nova Música</h2>
            
            <form method="post" >
                <div class="form-group">
                    <label for="nome">Nome da Música *</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        
                    >
                </div>

                <div class="form-group">
                    <label for="pais">País *</label>
                    <input 
                        type="text" 
                        id="pais" 
                        name="pais" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="anoinicio">Ano de Início da Carreira *</label>
                    <input 
                        type="number" 
                        id="anoinicio" 
                        name="anoinicio" 
                        
                    >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="lista.ejs" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('rodape.ejs')%>